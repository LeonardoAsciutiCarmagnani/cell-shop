# =============================================================================
# TOTVS Desafio Fullstack - Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env na raiz do monorepo:
#   pnpm setup
# =============================================================================

# -----------------------------------------------------------------------------
# Geral
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_ENV=development

# -----------------------------------------------------------------------------
# Docker Compose
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=totvs-desafio

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=totvs
POSTGRES_PASSWORD=totvs_dev_secret
POSTGRES_DB=totvs_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

DATABASE_URL=postgresql://totvs:totvs_dev_secret@localhost:5433/totvs_db

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------
CACHE_TTL_SECONDS=300
IDEMPOTENCY_TTL_SECONDS=86400

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_PORT=3000
API_HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Frontend 
# -----------------------------------------------------------------------------
WEB_PORT=5173

