{
  "name": "@totvs/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --allowImportingTsExtensions --rewriteRelativeImportExtensions",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit --allowImportingTsExtensions",
    "test": "tsx --test \"src/http/__tests__/*.spec.ts\""
  },
  "dependencies": {
    "@casecellshop/shared": "workspace:*",
    "@scalar/express-api-reference": "^0.9.19",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
